APP_NAME="Ansible Dashboard"
APP_ENV=production
APP_KEY=base64:GENERATE_WITH_php_artisan_key_generate
APP_DEBUG=false
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mariadb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ansible_dashboard
DB_USERNAME=ansible
DB_PASSWORD=your_db_password

# Redis (for queues, cache, websockets)
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

CACHE_DRIVER=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=480
QUEUE_CONNECTION=redis

# Laravel Reverb (WebSockets)
REVERB_APP_ID=ansible-dashboard
REVERB_APP_KEY=your_reverb_key
REVERB_APP_SECRET=your_reverb_secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

BROADCAST_CONNECTION=reverb

# Ansible SSH Control Node
ANSIBLE_SSH_HOST=192.168.1.10
ANSIBLE_SSH_PORT=22
ANSIBLE_SSH_USER=ansible
# Use key-based auth (recommended) or password
ANSIBLE_SSH_KEY_PATH=/home/www-data/.ssh/ansible_rsa
ANSIBLE_SSH_PASSWORD=
ANSIBLE_WORKING_DIR=/etc/ansible
ANSIBLE_INVENTORY_DEFAULT=/etc/ansible/inventory
ANSIBLE_PLAYBOOKS_DIR=/etc/ansible/playbooks
ANSIBLE_VAULT_PASSWORD_FILE=/etc/ansible/.vault_pass

# Security
ADMIN_SETUP_TOKEN=change_this_immediately
